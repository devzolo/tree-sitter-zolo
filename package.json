{
  "name": "tree-sitter-zolo",
  "version": "0.1.0",
  "description": "Zolo grammar for tree-sitter",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "zolo"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm"
  ],
  "author": "Zolo Lang authors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devzolo/zolo-lang.git",
    "directory": "tree-sitter-zolo"
  },
  "tree-sitter": [
    {
      "scope": "source.zolo",
      "file-types": [
        "zolo"
      ],
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "folds": "queries/folds.scm",
      "indents": "queries/indents.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "scripts": {
    "build": "tree-sitter generate && node-gyp build",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --strip",
    "test": "tree-sitter test"
  },
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "prebuildify": "^6.0.0",
    "tree-sitter-cli": "^0.26.8"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  }
}
